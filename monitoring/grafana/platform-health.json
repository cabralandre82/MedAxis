{
  "__comment": "Clinipharma — Platform health dashboard (Wave 11). Owns SLO-01, SLO-03, SLO-04, SLO-08. Import into Grafana with datasource variable $DS_PROM. Kept minimal: 6 panels, no plugins, compatible with Grafana 10+.",
  "title": "Clinipharma · Platform health",
  "uid": "clinipharma-platform-health",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "tags": ["clinipharma", "slo", "wave-11"],
  "templating": {
    "list": [
      {
        "name": "DS_PROM",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "SLO-01 · Checkout success (5m)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "$DS_PROM" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 0.99, "color": "yellow" },
              { "value": 0.995, "color": "green" }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(orders_created_total{outcome=\"ok\"}[5m])) / clamp_min(sum(rate(orders_created_total[5m])), 1e-9)"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "SLO-03 · Auth p95 (ms)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "$DS_PROM" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 400, "color": "yellow" },
              { "value": 800, "color": "red" }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_ms_bucket{path=~\"/api/auth/.*\"}[5m])))"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Outbound service success rate (SLO-08)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "$DS_PROM" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{service}}",
          "expr": "sum by (service) (rate(http_outbound_total{outcome=\"ok\"}[5m])) / clamp_min(sum by (service) (rate(http_outbound_total[5m])), 1e-9)"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Request rate by path",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "$DS_PROM" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{path}} · {{outcome}}",
          "expr": "sum by (path, outcome) (rate(http_request_total[1m]))"
        }
      ]
    },
    {
      "id": 5,
      "type": "table",
      "title": "Cron freshness (SLO-04)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "$DS_PROM" },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "displayMode": "auto" } }
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "instant": true,
          "expr": "time() - max by (job) (cron_last_success_ts)"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Outbound 3rd-party latency p95",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "$DS_PROM" },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{service}} p95",
          "expr": "histogram_quantile(0.95, sum by (service, le) (rate(http_outbound_duration_ms_bucket[5m])))"
        }
      ]
    }
  ]
}
