{
  "__comment": "Clinipharma — Security dashboard (Wave 11). Owns SLO-05 (rate-limit false positives) and surfaces CSRF, Turnstile, suspicious IP trends. Feeds the audit/security weekly review.",
  "title": "Clinipharma · Security",
  "uid": "clinipharma-security",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "tags": ["clinipharma", "security", "wave-11"],
  "templating": {
    "list": [
      {
        "name": "DS_PROM",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      },
      {
        "name": "bucket",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "$DS_PROM" },
        "query": "label_values(rate_limit_hits_total, bucket)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Rate-limit denied / hits (1h)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "$DS_PROM" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.01, "color": "yellow" },
              { "value": 0.05, "color": "red" }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(rate_limit_denied_total{bucket=~\"$bucket\"}[1h])) / clamp_min(sum(rate(rate_limit_hits_total{bucket=~\"$bucket\"}[1h])), 1e-9)"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "CSRF blocks (1h)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "$DS_PROM" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [{ "refId": "A", "expr": "sum(increase(csrf_blocked_total[1h]))" }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Turnstile fail rate (24h)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "$DS_PROM" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.05, "color": "yellow" },
              { "value": 0.2, "color": "red" }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(turnstile_verify_total{outcome=\"fail\"}[24h])) / clamp_min(sum(rate(turnstile_verify_total[24h])), 1e-9)"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Suspicious IPs (15m)",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "$DS_PROM" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 10, "color": "yellow" },
              { "value": 50, "color": "red" }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(rate_limit_suspicious_ips_total{severity=~\"warning|critical\"}[15m]))"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Rate-limit denials by bucket",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "$DS_PROM" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{bucket}}",
          "expr": "sum by (bucket) (rate(rate_limit_denied_total[1m]))"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Audit chain integrity",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "$DS_PROM" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "chain failures",
          "expr": "sum(increase(audit_chain_break_total[1h]))"
        },
        {
          "refId": "B",
          "legendFormat": "DSAR opened",
          "expr": "sum(increase(dsar_opened_total[1h]))"
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "SLO-11 · RLS canary violations (7d)",
      "description": "Hard SLO. Must be 0. Any non-zero value is a P0/P1 (depending on rls_canary.page_on_violation).",
      "gridPos": { "x": 0, "y": 12, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "$DS_PROM" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "red" }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(rls_canary_violations_total[7d]))"
        }
      ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "SLO-11 · Canary age (s)",
      "description": "Seconds since the last successful canary run. Should stay below ~90 000 (≈25h) given the daily 04:40 BRT schedule.",
      "gridPos": { "x": 6, "y": 12, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "$DS_PROM" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 90000, "color": "yellow" },
              { "value": 129600, "color": "red" }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(rls_canary_age_seconds)"
        }
      ]
    },
    {
      "id": 9,
      "type": "stat",
      "title": "SLO-11 · Tables in matrix",
      "description": "How many tables the canary exercised on the latest run. Drops without a migration are suspicious.",
      "gridPos": { "x": 12, "y": 12, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "$DS_PROM" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "yellow" },
              { "value": 30, "color": "green" }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(rls_canary_tables_checked)"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "RLS canary runs by outcome",
      "gridPos": { "x": 18, "y": 12, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "$DS_PROM" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{outcome}}",
          "expr": "sum by (outcome) (increase(rls_canary_runs_total[24h]))"
        }
      ]
    },
    {
      "id": 11,
      "type": "stat",
      "title": "SLO-12 · Oldest secret age (days)",
      "description": "Wave 15. Age in days of the most-overdue secret tracked by `secret_inventory`. Yellow at 60d (warning ahead of Tier A/B 90d limit), red at 90d+.",
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "$DS_PROM" },
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 60, "color": "yellow" },
              { "value": 90, "color": "red" }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(secret_oldest_age_seconds) / 86400"
        }
      ]
    },
    {
      "id": 12,
      "type": "stat",
      "title": "SLO-12 · Overdue secrets",
      "description": "Wave 15. Number of secrets currently past their tier-specific max age (90d Tier A/B, 180d Tier C). Hard SLO target = 0.",
      "gridPos": { "x": 6, "y": 16, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "$DS_PROM" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "red" }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(secret_rotation_overdue_count)"
        }
      ]
    },
    {
      "id": 13,
      "type": "stat",
      "title": "SLO-12 · Never-rotated secrets",
      "description": "Wave 15. Secrets present in the manifest but with no successful rotation row in the ledger. Should be 0 — non-zero implies manifest drift or missing genesis seed.",
      "gridPos": { "x": 12, "y": 16, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "$DS_PROM" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "red" }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(secret_rotation_never_rotated_count)"
        }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Secret rotation runs by tier+outcome",
      "description": "Wave 15. Weekly cron output by tier (A/B/C) and outcome (rotated/queued/requires_operator).",
      "gridPos": { "x": 18, "y": 16, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "$DS_PROM" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{tier}}/{{outcome}}",
          "expr": "sum by (tier, outcome) (increase(secret_rotation_runs_total[14d]))"
        }
      ]
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Secret rotation FAILURES",
      "description": "Wave 15. Any non-zero series here means a rotation attempt was rejected by the upstream (Vercel API, provider, DB). Investigate via `docs/runbooks/secret-compromise.md`.",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "$DS_PROM" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{tier}}/{{secret}}/{{reason}}",
          "expr": "sum by (tier, secret, reason) (increase(secret_rotation_failures_total[7d]))"
        }
      ]
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Per-secret age (days)",
      "description": "Wave 15. Tracks the age of every individual secret. Use this panel to forecast which secret rotates next.",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "$DS_PROM" },
      "fieldConfig": { "defaults": { "unit": "d" } },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{secret}}",
          "expr": "secret_age_seconds / 86400"
        }
      ]
    }
  ]
}
