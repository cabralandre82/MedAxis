# ============================================================
# Clinipharma — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://jomdntqlgrupvhrqoyai.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_DB_PASSWORD=your_database_password_here
# Wave 14 — RLS canary forges short-lived (60s) HS256 JWTs signed with
# this secret to call rls_canary_assert(uuid) as an unaffiliated
# authenticated user. Same secret PostgREST uses to validate every API
# call. Rotate together with the JWT secret in the Supabase dashboard.
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Clinipharma

# Email transacional — Resend (https://resend.com)
# Obtenha sua API key em: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here
# Remetente verificado no Resend (deve usar domínio verificado em produção)
EMAIL_FROM=Clinipharma <noreply@seudominio.com.br>

# Google OAuth (optional — disabled in MVP, keep empty to skip)
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── Wave 15 — Secret rotation cron (auto-rotation of Tier A) ──────────
# These three are required for /api/cron/rotate-secrets to actually
# rotate Tier A secrets via the Vercel API. Without them, the cron
# falls back to alert-only behaviour for Tier A as well as B/C.
#   VERCEL_TOKEN — Vercel API token with env-write scope on the project.
#                  Itself a Tier B secret — rotation procedure §3.2.7
#                  in docs/runbooks/secret-compromise.md.
#   VERCEL_PROJECT_ID — `prj_...` from Vercel project settings.
#   VERCEL_TEAM_ID    — `team_...` for team-owned projects (omit for
#                       personal accounts).
VERCEL_TOKEN=your_vercel_token_here
VERCEL_PROJECT_ID=prj_your_project_id_here
VERCEL_TEAM_ID=team_your_team_id_here
